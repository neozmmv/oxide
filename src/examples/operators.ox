void main() {
    // basic operations
    sum := 1 + 1;
    sub := 5 - 2;
    mul := 5 * 5;

    div := 10 / 2; // (int if both values are int)
    floatDiv := 7 / 2.0; // 3.5 (float if any of the values are float)

    // incremental / decremental
    i := 0;
    i++; // i = 1
    i--; // i = 0
    i += 6; // i = 6
    i -= 2; // i = 4

    power := 2**3; // 2 to the 3rd power (8)
    mod := 10 % 2; // 0
}